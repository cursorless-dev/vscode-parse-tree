{
  "name": "parse-tree",
  "displayName": "Parse tree",
  "description": "Access document syntax using tree-sitter",
  "version": "0.56.0",
  "publisher": "pokey",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pokey/vscode-parse-tree.git"
  },
  "icon": "images/icon.png",
  "main": "./out/extension.js",
  "files": [
    "out",
    "parsers",
    "images",
    "CHANGELOG.md"
  ],
  "license": "MIT",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Programming Languages",
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:agda",
    "onLanguage:c",
    "onLanguage:clojure",
    "onLanguage:cpp",
    "onLanguage:csharp",
    "onLanguage:css",
    "onLanguage:dart",
    "onLanguage:elixir",
    "onLanguage:elm",
    "onLanguage:gdscript",
    "onLanguage:gleam",
    "onLanguage:go",
    "onLanguage:haskell",
    "onLanguage:html",
    "onLanguage:java-properties",
    "onLanguage:java",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:jsonl",
    "onLanguage:julia",
    "onLanguage:kotlin",
    "onLanguage:latex",
    "onLanguage:lua",
    "onLanguage:markdown",
    "onLanguage:nix",
    "onLanguage:perl",
    "onLanguage:php",
    "onLanguage:properties",
    "onLanguage:python",
    "onLanguage:r",
    "onLanguage:ruby",
    "onLanguage:rust",
    "onLanguage:scala",
    "onLanguage:scm",
    "onLanguage:scss",
    "onLanguage:shellscript",
    "onLanguage:sparql",
    "onLanguage:starlark",
    "onLanguage:swift",
    "onLanguage:talon-list",
    "onLanguage:talon",
    "onLanguage:terraform",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:xml",
    "onLanguage:yaml",
    "onLanguage:zig"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {},
  "scripts": {
    "clean": "rm -rf ./out && rm -rf parsers",
    "vscode:prepublish": "npm run build",
    "build": "tsc -p . && npm run copy-assets",
    "copy-assets": "sh copy-assets.sh",
    "lint": "npm run typecheck && npm run lint:ts && npm run lint:fmt",
    "typecheck": "tsc -p . --noEmit",
    "lint:ts": "oxlint -c oxlint.config.mts --deny-warnings .",
    "lint:fmt": "oxfmt --check .",
    "fix": "npm run fix:ts && npm run fix:fmt",
    "fix:ts": "oxlint -c oxlint.config.mts --fix .",
    "fix:fmt": "oxfmt ."
  },
  "dependencies": {
    "semver": "^7.7.4",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@cursorless/tree-sitter-wasms": "^0.8.1",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.7.1",
    "@types/vscode": "1.98.0",
    "oxfmt": "^0.44.0",
    "oxlint-tsgolint": "^0.20.0",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2"
  }
}
